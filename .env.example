# Copy to .env and fill in before `docker compose up`.

# AES-256 key (base64, 32 bytes) that seals OAuth tokens at rest. REQUIRED.
# Generate one:  openssl rand -base64 32
TSENGINE_SECRET_KEY=

# Operator/API bearer token. Users sign in with email/password; this is for the
# operator API (POST /v1/tenants), Slack callbacks, and tests. Generate:
#   openssl rand -hex 32
TSENGINE_PLATFORM_TOKEN=dev-token

# Database. Empty → the prod compose default (/data/platform.db, local SQLite on a Docker
# volume). For managed Postgres (Supabase / RDS / Neon), set the connection DSN here — the
# backend auto-creates its schema and becomes stateless (no disk needed). Supabase example:
#   TSENGINE_PLATFORM_DB=postgresql://postgres:PASSWORD@db.<ref>.supabase.co:5432/postgres?sslmode=require
TSENGINE_PLATFORM_DB=

# Public base URL of the platform (used to build OAuth redirect URIs). On EC2 behind the
# Caddy TLS edge, set this to your https domain (and TSENGINE_SITE_ADDRESS + TSENGINE_ACME_EMAIL).
TSENGINE_PLATFORM_PUBLIC=http://localhost:8090

# Continuous-monitoring re-scan cadence (e.g. 6h; 0 disables). Default 12h.
TSENGINE_MONITOR_INTERVAL=12h

# Verifies inbound webhooks (recommended in production; empty = unverified).
TSENGINE_WEBHOOK_SECRET=

# Observability. Logs go to stderr; set json in production for a log pipeline.
# Prometheus scrapes GET /metrics (network-restrict it — it is not auth-gated).
TSENGINE_LOG_FORMAT=json
TSENGINE_LOG_LEVEL=info

# Background-scan worker pool (Scan now / webhook re-scans run off the request path).
TSENGINE_SCAN_WORKERS=2
TSENGINE_SCAN_TIMEOUT=30m
