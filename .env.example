# Copy to .env and fill in before `make deploy-prod` (or `docker compose up`).
# Grouped: REQUIRED core first, then the production surfaces (HTTPS, email, AI),
# then OPTIONAL integrations. Anything left blank degrades gracefully — the app
# still runs, that feature is just off (and says so honestly).

# ─────────────────────────────────────────────────────────────────────────────
# 1. REQUIRED — the app will not start (or won't be safe) without these
# ─────────────────────────────────────────────────────────────────────────────

# AES-256 key (base64, 32 bytes) that seals OAuth tokens + tenant secrets at rest. REQUIRED.
# Generate:  openssl rand -base64 32
TSENGINE_SECRET_KEY=

# Operator/API bearer token. Users sign in with email/password; this is for the operator
# API (POST /v1/tenants), Slack callbacks, and the cross-tenant practitioner desk. The prod
# compose REFUSES to start if unset. Generate:  openssl rand -hex 32
TSENGINE_PLATFORM_TOKEN=

# Database — one switch: SQLite now, Postgres to deploy.
#   unset            → durable local SQLite (binary: ./platform.db; prod compose: /data on a volume)
#   postgres:// DSN  → managed Postgres (Supabase / RDS / Neon); schema auto-creates, backend
#                      goes stateless (run N boxes behind an LB). Recommended for production:
#   TSENGINE_PLATFORM_DB=postgresql://postgres:PASSWORD@db.<ref>.supabase.co:5432/postgres?sslmode=require
#   memory           → ephemeral (throwaway runs only)
TSENGINE_PLATFORM_DB=

# ─────────────────────────────────────────────────────────────────────────────
# 2. HTTPS / public domain — needed for a real internet-facing deploy
#    (consumed by docker/caddy/Caddyfile via docker-compose.prod.yml)
# ─────────────────────────────────────────────────────────────────────────────

# The domain Caddy serves + gets a Let's Encrypt cert for. Also DROP `tls internal`
# in docker/caddy/Caddyfile so Caddy uses public ACME instead of its localhost CA.
TSENGINE_SITE_ADDRESS=app.yourdomain.com
TSENGINE_ACME_EMAIL=you@yourdomain.com

# Public base URL of the platform — used to build OAuth redirect URIs + email links.
# Behind the Caddy TLS edge this is your https domain.
TSENGINE_PLATFORM_PUBLIC=https://app.yourdomain.com

# ─────────────────────────────────────────────────────────────────────────────
# 3. Email (SMTP) — REQUIRED for password reset + member invites to actually send.
#    Unset → reset links are logged to stderr instead of emailed (dev fallback).
# ─────────────────────────────────────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=TensorShield <no-reply@yourdomain.com>

# ─────────────────────────────────────────────────────────────────────────────
# 4. The AI brain (L2 agents + plain-English brief). Unset → AI features are OFF
#    (operator-global fallback; tenants can still bring their own key in Settings).
#    LLM_PROVIDER: openai | anthropic | ollama (or compatible). For a local Ollama,
#    set LLM_BASE_URL=http://host.docker.internal:11434/v1 and LLM_API_KEY=ollama.
# ─────────────────────────────────────────────────────────────────────────────
LLM_PROVIDER=
LLM_API_KEY=
LLM_MODEL=
LLM_BASE_URL=

# ─────────────────────────────────────────────────────────────────────────────
# 5. OPTIONAL — connector OAuth apps. Set the pair for each system you want
#    customers to connect; unset connectors simply don't appear as options.
# ─────────────────────────────────────────────────────────────────────────────
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITLAB_CLIENT_ID=
GITLAB_CLIENT_SECRET=
BITBUCKET_CLIENT_ID=
BITBUCKET_CLIENT_SECRET=
AZURE_DEVOPS_CLIENT_ID=
AZURE_DEVOPS_CLIENT_SECRET=
AZURE_DEVOPS_ORG=
# Identity / non-tech (Workspace posture):
GWORKSPACE_CLIENT_ID=
GWORKSPACE_CLIENT_SECRET=
M365_CLIENT_ID=
M365_CLIENT_SECRET=
OKTA_CLIENT_ID=
OKTA_CLIENT_SECRET=
OKTA_ORG_URL=
# Ticketing (operator-default Jira; tenants can also set their own in Settings):
JIRA_BASE_URL=
JIRA_EMAIL=
JIRA_API_TOKEN=
JIRA_PROJECT=

# ─────────────────────────────────────────────────────────────────────────────
# 6. OPTIONAL — notifications (operator-global fallback; tenants route to their own
#    Slack webhook from Settings). Slack signing secret verifies approval buttons.
# ─────────────────────────────────────────────────────────────────────────────
TSENGINE_SLACK_WEBHOOK=
TSENGINE_SLACK_SIGNING_SECRET=
TSENGINE_TEAMS_WEBHOOK=
TSENGINE_DISCORD_WEBHOOK=
TSENGINE_WEBHOOK_URL=
TSENGINE_WEBHOOK_SIGNING_SECRET=

# ─────────────────────────────────────────────────────────────────────────────
# 7. Tuning / ops (sane defaults shown)
# ─────────────────────────────────────────────────────────────────────────────

# Continuous-monitoring re-scan cadence (e.g. 6h; 0 disables). Default 12h.
TSENGINE_MONITOR_INTERVAL=12h

# Verifies inbound webhooks (recommended in production; empty = unverified).
TSENGINE_WEBHOOK_SECRET=

# Observability. Logs to stderr; json in production for a log pipeline.
# Prometheus scrapes GET /metrics (network-restrict it — it is NOT auth-gated).
TSENGINE_LOG_FORMAT=json
TSENGINE_LOG_LEVEL=info

# Background-scan worker pool (Scan now / webhook re-scans run off the request path).
TSENGINE_SCAN_WORKERS=2
TSENGINE_SCAN_TIMEOUT=30m
