import http.server

class H(http.server.BaseHTTPRequestHandler):
    def log_message(self, *a): pass
    def do_GET(self):
        # "fix": disable the endpoint by 500-ing everything — kills the exploit by breaking the app
        self.send_response(500); self.end_headers(); self.wfile.write(b"service disabled")

http.server.HTTPServer(("0.0.0.0", 8000), H).serve_forever()
